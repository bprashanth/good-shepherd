{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": "textract:AnalyzeDocument",
      "Resource": "*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::fomomon",
        "arn:aws:s3:::fomomon/*",
        "arn:aws:s3:::fomomonguest",
        "arn:aws:s3:::fomomonguest/*",
        "arn:aws:s3:::forestfomo-images",
        "arn:aws:s3:::forestfomo-images/*"
      ]
    }
  ]
}
